# Postgres connection string. Works with Vercel Postgres, Neon, Supabase,
# Railway, or any managed Postgres. See README.md "Database setup".
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# NextAuth
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-random-32-byte-secret"
# Your deployed URL in production, http://localhost:3000 in development.
NEXTAUTH_URL="http://localhost:3000"

# Used to build absolute URLs in metadata, sitemap.xml, and robots.txt.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# First admin account — read once by `npm run db:seed` to create/update
# the admin login. Change the password after your first login isn't
# supported yet from the UI; re-run the seed with a new password instead.
ADMIN_EMAIL="admin@digitalhub.agency"
ADMIN_PASSWORD="change-this-before-seeding"
